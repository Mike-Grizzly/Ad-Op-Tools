# Supabase — get from your project dashboard at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Encryption key for OAuth tokens at rest (AES-256-GCM). Server-only — never expose.
# Must be a 32-byte random key, base64-encoded. Generate with: openssl rand -base64 32
# Use a DIFFERENT key per environment (dev vs prod).
TOKEN_ENCRYPTION_KEY=

# Ad Platform Integrations (add keys as each platform is connected)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
GTM_CLIENT_ID=
GTM_CLIENT_SECRET=
